{
  "manifest_version": 3,
  "name": "ENGAGEDLOOP",
  "version": "1.0.0",
  "description": "Reply smarter on X when you don't know what to say",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://generativelanguage.googleapis.com/ https://ioyqxwmgfdqzokwqpgdv.supabase.co/"
  },
  "permissions": [
    "activeTab",
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://ioyqxwmgfdqzokwqpgdv.supabase.co/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup-brutalist.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": ["content-brutalist.js"],
      "run_at": "document_idle"
    }
  ]
}
